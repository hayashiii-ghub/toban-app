{
  "name": "toban",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host",
    "dev:api": "node scripts/ensure-dist.mjs && wrangler dev --port 8788",
    "dev:full": "concurrently \"pnpm dev\" \"pnpm dev:api\"",
    "build": "vite build",
    "deploy:cf": "node scripts/prepare-wrangler-config.mjs --require && wrangler d1 migrations apply toban-maker-db --config wrangler.deploy.jsonc && wrangler deploy --config wrangler.deploy.jsonc",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply toban-maker-db --local",
    "format": "prettier --write .",
    "og:generate": "node scripts/generate-og-image.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "react-doctor": "react-doctor"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sentry/react": "^10.52.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "hono": "^4.12.18",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-qr-code": "^2.0.21",
    "resend": "^6.12.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "wouter": "^3.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react-doctor": "^0.2.8",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.95.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.1",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}
